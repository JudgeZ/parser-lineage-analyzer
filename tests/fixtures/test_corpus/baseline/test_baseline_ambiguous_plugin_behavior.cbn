# TEST EXPECTATION:
# The parser must accurately model the behavior when multiple parsing plugins target the same source field and output fields.
# If `json` fails, `grok` runs. If `json` succeeds, does `grok` still run? The parser must know the implied execution flow.
# Furthermore, if both attempt to populate the `user` field, the parser must track whether the field is overwritten, appended (turned into array), or ignored.

filter {
  # Attempt JSON parsing first
  json {
    source => "payload"
    target => "parsed_data"
    tag_on_failure => ["_jsonparsefailure"]
  }

  # Attempt dissect on the same payload, regardless of JSON success/failure
  dissect {
    mapping => {
      "payload" => "%{timestamp} %{user} %{action}"
    }
    # Dissect doesn't overwrite by default in some configurations unless specified,
    # but let's see how the parser handles potential field collision
  }

  if "_jsonparsefailure" in [tags] {
    # Fallback grok if json failed
    grok {
      match => { "payload" => "user=%{WORD:user} action=%{WORD:action}" }
    }
  } else {
     # If json succeeded, we might have parsed_data.user. We pull it up to top level.
     mutate {
       rename => { "[parsed_data][user]" => "user" }
     }
  }
}
