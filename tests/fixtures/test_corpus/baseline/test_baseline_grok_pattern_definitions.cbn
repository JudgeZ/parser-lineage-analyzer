# BASELINE: Grok Pattern Definitions
# Validates that `pattern_definitions` inside a `grok` block does not break the parser.
# The tool MUST handle the nested dictionary structure mapping custom pattern names
# to their regex strings, and properly understand the main `match` array.
# EXPECTED BEHAVIOR: Grok parsing should succeed, custom pattern shouldn't cause errors.
filter {
  grok {
    pattern_definitions => {
      "CUSTOM_ID" => "[A-Z]{3}-[0-9]{4}-[A-Z0-9]+"
      "WEIRD_DATE" => "\d{2}_\d{2}_\d{4}"
    }
    match => { "message" => "%{CUSTOM_ID:my_id} %{WEIRD_DATE:my_date} %{GREEDYDATA:rest}" }
  }
}
