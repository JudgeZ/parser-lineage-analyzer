# BASELINE REPRODUCTION: CIDR Plugin Network Match
# Validates the parser correctly identifies CIDR network matching.
# EXPECTED BEHAVIOR: The parser MUST track the lineage of the network check
# and any resulting tags or field modifications accurately.
filter {
  cidr {
    add_tag => [ "internal_ip" ]
    address => [ "%{clientip}" ]
    network => [ "10.0.0.0/8", "192.168.0.0/16", "172.16.0.0/12" ]
  }

  if "internal_ip" in [tags] {
    mutate {
      add_field => { "network_zone" => "internal" }
    }
  }
}
