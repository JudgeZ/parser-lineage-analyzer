# BASELINE REPRODUCTION: JSON Parsing with KV Fallback
# Validates a common pattern where JSON parsing is attempted,
# and if it fails (using the failure tag), KV parsing is applied instead.
# The tool MUST track the implicit dependency on the JSON failure tag.
# EXPECTED BEHAVIOR: AST formed, tag-based routing handles the conditional execution.
filter {
  json {
    source => "raw_payload"
    target => "parsed_data"
    tag_on_failure => [ "_jsonparsefailure" ]
  }
  if "_jsonparsefailure" in [tags] {
    kv {
      source => "raw_payload"
      value_split => "="
      field_split => "&"
      target => "parsed_data"
    }
    mutate {
      remove_tag => [ "_jsonparsefailure" ]
    }
  }
}
