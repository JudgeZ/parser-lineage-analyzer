# TEST BEHAVIOR:
# Simulates extreme string replacement and escaping that is common in Windows
# event logs or command line auditing. The parser must correctly interpret
# the Logstash string escape rules and correctly track the lineage of the 
# interpolated fields `domain` and `user`.
filter {
  mutate {
    replace => {
      "full_account" => "%{domain}\\%{user}\" - \\\"Admin\\\""
    }
  }

  if "Admin" in [full_account] {
    mutate {
      add_tag => ["privileged_account"]
    }
  }
}
