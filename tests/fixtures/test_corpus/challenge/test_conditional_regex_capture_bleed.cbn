# CHALLENGE: Conditional Regex Capture Bleed
# Validates that the parser can identify inline named regex captures inside conditional statements
# and correctly scope those newly created fields.
# In complex configs, `if [field] =~ /(?<extracted_token>.*)/` creates a field that is
# often used immediately inside the conditional block.
# The tool MUST parse the regex literal, extract the capture group names, and add them
# to the known lineage/variables available in subsequent operations.
# EXPECTED BEHAVIOR: `extracted_token` is recognized as a valid field generated by the conditional.
filter {
  if [message] =~ /(?<extracted_token>^[A-Z]+):\s+(?<status_code>\d{3})/ {
    mutate {
      add_field => { "status" => "%{status_code}" }
      add_field => { "type" => "%{extracted_token}" }
    }
  }
}
