# TEST BEHAVIOR:
# Complex boolean logic involving uninitialized fields. In large configurations,
# many fields might not exist. The parser must correctly model the truth table
# for `if ![field]` vs `if [field] == ""` vs `if [field] not in [...]`.
# It must handle the operator precedence correctly and resolve the control flow.
filter {
  if (![src_ip] and [dst_ip]) or ([protocol] not in ["tcp", "udp", "icmp"] and ![action_taken]) {
    mutate {
      add_tag => ["suspicious_traffic_pattern"]
    }
  } else if [src_ip] == "" or [dst_ip] == "" {
    drop {}
  }
}
