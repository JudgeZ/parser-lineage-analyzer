# TEST BEHAVIOR:
# Challenges the parser to handle Grok patterns that specify deep nested
# object paths directly in the capture group names.
# The parser must create the implicit object hierarchy `user -> auth -> token`
# and map the extracted regex match to that deep field.
filter {
  grok {
    match => {
      "message" => "AuthToken: %{UUID:[user][auth][token]} for User: %{WORD:[user][username]}"
    }
  }

  if [user][auth][token] {
    mutate {
      add_tag => ["authenticated"]
    }
  }
}
