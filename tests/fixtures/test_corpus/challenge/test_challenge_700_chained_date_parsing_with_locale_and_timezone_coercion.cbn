# EXPECTED BEHAVIOR:
# 1. The parser must handle the `date` plugin with multiple match patterns, custom locale (`fr-FR`), and a dynamic `timezone` derived from `[event_tz]`.
# 2. It must understand the `tag_on_failure` and how it dictates the fallback flow.
# 3. If the first date parse fails (e.g., `[event_tz]` is invalid or the format doesn't match), it falls back to a second `date` plugin.
# 4. The second date plugin uses a hardcoded timezone but targets a different field (`[backup_timestamp]`).
# 5. The parser must track that `@timestamp` is only overwritten if the first `date` block succeeds, and `[backup_timestamp]` is created only if the first fails and the second succeeds.
# 6. It must properly model the dependency: if `[event_tz]` is manipulated earlier in the pipeline, the first date plugin's outcome depends on that manipulation.

filter {
  # Assume event_tz is something like "Europe/Paris"
  date {
    match => [ "timestamp_string", "MMM dd HH:mm:ss", "MMM  d HH:mm:ss", "ISO8601" ]
    target => "@timestamp"
    timezone => "%{event_tz}"
    locale => "fr-FR"
    tag_on_failure => ["_primary_date_failure"]
  }

  if "_primary_date_failure" in [tags] {
    # Fallback with different config
    date {
      match => [ "backup_timestamp_string", "UNIX", "UNIX_MS" ]
      target => "backup_timestamp"
      timezone => "UTC"
      tag_on_failure => ["_total_date_failure"]
    }
  }

  if "_total_date_failure" not in [tags] {
    mutate {
      add_tag => ["time_parsed_successfully"]
    }
  }
}
