# TEST OBJECTIVE: Validate date parsing with multiple fallback formats, locale coercion, and dynamic target overwrites.
# EXPECTED BEHAVIOR:
# 1. The parser MUST recognize the `date` block attempting multiple matches.
# 2. It MUST handle the `locale` field.
# 3. It MUST trace the `target` field being dynamically generated.
# 4. It MUST handle `tag_on_failure` being suppressed.

filter {
  date {
    match => [ "timestamp_field", "MMM  d HH:mm:ss", "MMM dd HH:mm:ss", "ISO8601" ]
    target => "%{[metadata][time_target]}"
    locale => "en"
    timezone => "UTC"
    tag_on_failure => []
  }

  if !["%{[metadata][time_target]}"] {
    mutate {
      add_field => { "%{[metadata][time_target]}" => "%{@timestamp}" }
    }
  }
}
