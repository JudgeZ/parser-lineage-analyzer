# TEST BEHAVIOR:
# This test simulates a `grok` filter that defines an inline custom pattern dictionary with many complex regexes containing lookaheads and lookbehinds.
# Expected parsing behavior:
# - The parser must correctly extract all `pattern_definitions`.
# - It must parse the complex regex patterns within the `match` array, including escaped quotes and brackets.
# - It should handle the potential catastrophic backtracking risks in the regexes if the parser does static analysis.
# - It should accurately capture multiple match arrays and break_on_match logic.

filter {
  grok {
    break_on_match => true
    pattern_definitions => {
      "CUSTOM_GUID" => "[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{12}"
      "LOOKAHEAD_IP" => "(?<=IP:)\\s*(?:[0-9]{1,3}\\.){3}[0-9]{1,3}"
      "NEGATIVE_LOOKBEHIND_USER" => "(?<!Admin|System)[A-Za-z0-9_]{3,16}"
      "COMPLEX_NESTED_BRACKETS" => "\\[(?:[^\\[\\]]|\\[(?:[^\\[\\]]|\\[[^\\[\\]]*\\])*\\])*\\]"
      "GREEDY_WITH_TIMEOUT_RISK" => ".*?(?:error|warn|fatal).*?(?:user|account).*?(?:failed|denied).*"
    }
    match => {
      "message" => [
        # Pattern 1: Uses lookarounds and custom patterns
        "^%{TIMESTAMP_ISO8601:timestamp} %{LOOKAHEAD_IP:client_ip} User:%{NEGATIVE_LOOKBEHIND_USER:user} Session:%{CUSTOM_GUID:session_id}",
        
        # Pattern 2: Heavy recursion / nested brackets simulation
        "^%{TIMESTAMP_ISO8601:timestamp} %{LOGLEVEL:level} Context:%{COMPLEX_NESTED_BRACKETS:context_data} MSG:%{GREEDY_WITH_TIMEOUT_RISK:error_msg}",
        
        # Pattern 3: Standard fallback but with escaped quotes
        "^%{TIMESTAMP_ISO8601:timestamp} MSG=\"%{DATA:quoted_msg}\" STATUS=\\[%{NUMBER:status}\\]"
      ]
    }
    tag_on_failure => ["_grokparsefailure_complex"]
    timeout_millis => 500
  }
}
