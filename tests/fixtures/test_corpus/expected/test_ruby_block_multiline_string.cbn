# EXPECTED BEHAVIOR:
# The parser must handle multiline string literals within the `ruby` block's `code` parameter.
# The parser should not truncate the string or fail on internal newlines, quotes, or comment characters inside the string literal.
# `computed_value` should be recorded as generated by an opaque Ruby block.

filter {
  ruby {
    code => "
      # This is a comment inside the ruby code block
      event.set('computed_value', 1)
      if event.get('some_field') == 'test'
        event.set('computed_value', 2)
      end
    "
  }
}
