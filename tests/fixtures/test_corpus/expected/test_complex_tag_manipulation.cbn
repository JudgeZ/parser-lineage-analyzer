# EXPECTED BEHAVIOR:
# 1. Parser must correctly track the `tags` array state.
# 2. Should handle checking for tag existence using the `in` and `not in` operators.
# 3. Should handle adding tags via `add_tag` (in any filter) and removing via `remove_tag`.
# 4. Must gracefully handle cases where `tags` might be a string instead of an array 
#    before the operation, though usually it's forced to an array.

filter {
  grok {
    match => { "message" => "%{SYSLOGBASE} %{GREEDYDATA:syslog_message}" }
    add_tag => [ "syslog", "parsed" ]
    tag_on_failure => [ "_grokparsefailure_syslog" ]
  }

  if "_grokparsefailure_syslog" not in [tags] {
    mutate {
      add_tag => [ "success_path" ]
    }
  } else {
    mutate {
      remove_tag => [ "parsed" ]
      add_tag => [ "needs_manual_review" ]
    }
  }

  if "syslog" in [tags] and "success_path" in [tags] {
    mutate {
      add_field => { "processing_status" => "complete" }
    }
  }
}
