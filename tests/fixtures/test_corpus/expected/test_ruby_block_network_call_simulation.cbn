# EXPECTED BEHAVIOR:
# This test verifies how the parser handles custom ruby blocks that attempt complex operations,
# potentially including exception handling, multi-line logic, and simulating operations that might
# fail (like invalid object manipulation).
# The parser must correctly generate the AST for the ruby block without crashing.
# If the ruby code raises an exception during execution, it must be rescued within the block
# or handled gracefully by the parser framework, logging an error instead of halting the pipeline.

filter {
  ruby {
    code => "
      begin
        # Simulating complex logic or data transformation that might throw an exception
        raw_val = event.get('complex_nested_field')
        if raw_val.is_a?(String)
          processed_val = raw_val.reverse.upcase
          event.set('processed_val', processed_val)
        else
          # Force an exception to test rescue block parsing
          raise TypeError.new('Expected a string but got something else')
        end
      rescue => e
        event.tag('ruby_processing_error')
        event.set('ruby_error_message', e.message)
      end
    "
  }

  if "ruby_processing_error" in [tags] {
    mutate {
      add_field => { "pipeline_status" => "degraded" }
    }
  }
}
