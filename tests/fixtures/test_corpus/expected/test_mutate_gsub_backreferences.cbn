# EXPECTED BEHAVIOR:
# Tests the parser's regex handling within a `gsub` mutate operation, specifically
# the use of capture groups and backreferences in the replacement string.
# Large parsers use complex gsub rules to sanitize data.
# The parser's lexer must not break on escaped backslashes, complex regex literals, 
# and group references (e.g., `\1` or `\2`).

filter {
  mutate {
    gsub => [
      # Remove quotes around a specific word
      "message", "(\")(\w+)(\")", "\2",
      
      # Mask credit card numbers, keeping last 4 digits
      "payment_info", "\b(?:\d[ -]*?){13,16}\b", "****-****-****-\1",
      
      # Fix path slashes
      "file_path", "\\\\", "/",
      
      # Complex nested groups
      "complex_field", "(^\[.*?\])\s+(.*?)\s+(.*)", "\1 - \3 (\2)"
    ]
  }

  if [message] =~ /ERROR \d+/ {
    mutate {
      add_tag => [ "matched_error" ]
    }
  }
}
