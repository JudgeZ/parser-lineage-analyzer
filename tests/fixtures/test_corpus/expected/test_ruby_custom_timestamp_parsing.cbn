# EXPECTED BEHAVIOR:
# This test challenges the analyzer's capacity to handle ruby blocks that manipulate the special
# @timestamp field or create entirely new DateTime objects from string manipulations.
# The tool should recognize that this ruby block acts as a complex date parser, potentially
# skipping or augmenting standard date plugins.
filter {
  ruby {
    code => "
      begin
        raw_time = event.get('raw_time_string')
        if raw_time
          # Custom weird parsing logic
          parts = raw_time.split('-')
          if parts.length == 3
            time_obj = Time.mktime(parts[0], parts[1], parts[2])
            event.set('@timestamp', LogStash::Timestamp.new(time_obj))
            event.set('time_parsed_by_ruby', true)
          end
        end
      rescue => e
        event.tag('_rubyexception_time')
      end
    "
  }
}
