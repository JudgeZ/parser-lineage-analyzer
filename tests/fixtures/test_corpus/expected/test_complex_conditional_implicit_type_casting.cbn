# EXPECTED BEHAVIOR:
# The parser must recognize that `status_code` is being implicitly compared as an integer in the first conditional
# and as a string in the second. It should correctly handle implicit type casting in the lineage graph, marking
# `status_code` as potentially polymorphic or tracking the coerced types independently.
filter {
  if [status_code] == 200 {
    mutate { add_tag => ["success"] }
  }
  if [status_code] == "404" {
    mutate { add_tag => ["not_found"] }
  }
  if [status_code] > 500 {
    mutate { add_tag => ["server_error"] }
  }
}
