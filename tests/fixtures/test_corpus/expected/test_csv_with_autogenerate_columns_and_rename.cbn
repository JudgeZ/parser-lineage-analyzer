/*
 * EXPECTED BEHAVIOR:
 * When a CSV plugin runs without `columns` defined, Logstash often autogenerates column1, column2, etc. (or users assume so).
 * The parser needs to handle implicit column names and subsequent mutations that refer to these autogenerated names.
 * Here, we parse a raw message and then rename `column1` to `id` and `column2` to `name`.
 * The lineage tracker should map `id` and `name` back to the raw CSV fields.
 */
filter {
  csv {
    source => "raw_message"
    separator => ","
    skip_header => "false"
  }
  
  mutate {
    rename => {
      "column1" => "event_id"
      "column2" => "event_type"
      "column3" => "severity"
    }
    convert => {
      "severity" => "integer"
    }
  }
}
