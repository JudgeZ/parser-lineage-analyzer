# EXPECTED BEHAVIOR:
# This test evaluates the parser's ability to handle dynamic field names
# generated by Grok captures where the pattern name itself is a reference or
# uses complex naming conventions.
# The parser should track the creation of the dynamic field based on the pattern match.

filter {
  grok {
    match => { "message" => "%{SYSLOGBASE} %{DATA:[dynamic_nested][field_%{log_type}]}" }
  }
}
