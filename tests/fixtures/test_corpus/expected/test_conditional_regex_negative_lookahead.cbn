# EXPECTED BEHAVIOR:
# This test evaluates the parser's ability to handle complex regular expressions
# in conditionals, specifically negative lookahead assertions.
# The parser must correctly identify the regex boundary and the lookahead
# syntax (?!...) without treating it as a syntax error.
# The lineage analyzer should identify the dependency on the 'message' field.

filter {
  if [message] =~ /ERROR: (?!Connection refused).*/ {
    mutate {
      add_tag => [ "unknown_error" ]
    }
  } else if [message] =~ /^(?:[0-9]{1,3}\.){3}[0-9]{1,3}$/ {
    mutate {
      add_tag => [ "ip_message" ]
    }
  }
}
