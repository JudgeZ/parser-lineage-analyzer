# EXPECTED BEHAVIOR:
# XML payloads often contain repeated elements. Users extract these using XPath
# into arrays, then often need to correlate them.
# The parser must handle arrays generated by xml xpath and subsequent mutations.
filter {
  xml {
    source => "raw_xml"
    target => "parsed_doc"
    xpath => {
      "//User/Name/text()" => "user_names"
      "//User/Role/text()" => "user_roles"
    }
  }

  if [user_names] and [user_roles] {
    ruby {
      code => "
        names = event.get('user_names')
        roles = event.get('user_roles')
        if names.is_a?(Array) && roles.is_a?(Array) && names.length == roles.length
          combined = []
          names.each_with_index do |name, idx|
            combined << { 'name' => name, 'role' => roles[idx] }
          end
          event.set('users', combined)
          event.remove('user_names')
          event.remove('user_roles')
        end
      "
    }
  }
}
